# ============================================================================
#  Talaria boot manager configuration
#  Location on the EFI System Partition (ESP):  \EFI\talaria\boot.conf
#
#  Notes on paths:
#    - All file paths are RELATIVE TO THE ROOT OF THE ESP and use back-slashes,
#      e.g.  \EFI\talaria\icons\arch.png
#    - Colors are hex in the form  #RRGGBB  (e.g. #7AA2F7).
#    - Lines starting with '#' are comments. Whitespace around '=' is ignored.
# ============================================================================

# --- Global settings --------------------------------------------------------

# Seconds before the default entry auto-boots:
#    N   wait N seconds, then boot the default entry
#   -1   never auto-boot - wait for the user to choose
#    0   boot the default entry immediately (skips the menu entirely)
timeout=5

# Index of the default entry (0-based, in the order entries appear below).
default=0

# 1 = suppress all boot-progress text (plain black screen during hand-off to
# the OS instead of "Booting <name>..."). 0 = show progress text.
quiet=0

# --- Colors -----------------------------------------------------------------
# Title text color.
#title_color=#7AA2F7
# Default color for every entry's name (per-entry "color=" overrides this).
#name_color=#C0CAF5
# Accent color of the selection highlight.
#highlight_color=#7AA2F7
# Background color.
#bg_color=#1a1b26

# ============================================================================
#  Menu keys
#    Left/Right                move between boot entries
#    Enter                     boot the focused entry 
#    Esc                       boot the default entry
# ============================================================================

# --- Background -------------------------------------------------------------
# Full-screen background image (BMP). Omit for a solid backdrop.
#background=\EFI\talaria\backgrounds\default.bmp

# ----------------------------------------------------------------------------
#  Boot entry format
#    entry {                                    
#        name      = "Display Name"
#        icon      = \path\to\icon.png
#        kernel    = \path\to\kernel-or-efi
#        initrd    = \path\to\initrd          (optional)
#        cmdline   = "kernel command line"    (optional)
#        color     = #RRGGBB                  (optional per-entry name color)
#        sha256    = <64 hex chars>           (optional - pin the image hash)
#    }
#
#  Auto-detection (used only when boot.conf is absent, or has no entries):
#    Talaria scans the ESP for kernels instead of guessing fixed paths -
#      * \EFI\Linux\*.efi          Unified Kernel Images (each becomes an entry)
#      * \boot\vmlinuz*, \vmlinuz* raw kernels (fallback if no UKIs found)
#      * \EFI\Microsoft\Boot\bootmgfw.efi   Windows Boot Manager
# ----------------------------------------------------------------------------

# Linux example - EFI stub kernel or Unified Kernel Image (UKI).
# For a UKI, point "kernel" at the .efi and omit initrd/cmdline.
# For a plain stub kernel, supply initrd and cmdline as shown.
#entry {
#    name    = "Arch Linux"
#    icon    = \EFI\talaria\icons\arch.bmp
#    color   = #1793D1
#    kernel  = \vmlinuz-linux
#    initrd  = \initramfs-linux.img
#    cmdline = "root=PARTUUID=CHANGE-ME-TO-YOUR-ROOT-PARTUUID......"
#}

# Windows example - chainloads the Windows Boot Manager. "kernel" is the path
# to bootmgfw.efi; Talaria detects the PE image and loads it via its device path
# so the BCD is found.
#entry {
#    name   = "Windows 11"
#    icon   = \EFI\talaria\icons\windows.bmp
#    kernel = \EFI\Microsoft\Boot\bootmgfw.efi
#}
